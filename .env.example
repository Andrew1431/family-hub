# Family Hub secrets. Copy this file to `.env` (gitignored) and fill in values.
# Only secret VALUES go here — never commit a real .env.

# Claude API key for the AI assistant (API billing only; not a Pro/Max login).
ANTHROPIC_API_KEY=

# Shared Google OAuth client for ALL Google modules (calendar, tasks, …).
# Create one "Web application" OAuth client in Google Cloud and reuse it
# everywhere. Register this redirect URI on that client:
#   http://localhost:4000/api/m/calendar-google/oauth/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
