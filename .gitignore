node_modules/
dist/
*.tsbuildinfo

# Lockfile intentionally untracked: private/external modules dropped into
# modules/ would otherwise churn it on every install. Personal project — we
# accept losing pinned-tree reproducibility for clones/CI.
pnpm-lock.yaml

# Generated by gen-modules.mjs
packages/ui/src/modules.generated.ts

# Local, user-tweakable config seeded from committed *.template.* files
config/theme.local.css
config/layout.local.json
config/hub.local.json

# Modules: ignore everything dropped into modules/ except the core (committed)
# ones listed below. Private/personal or third-party modules just live in
# modules/<name> and are tracked as their own separate git repos. Add a line
# here when you create a NEW core module that ships with the base package.
modules/*
!modules/assistant/
!modules/calendar-google/
!modules/clock/
!modules/google-oauth/
!modules/notes/
!modules/photos-drive/
!modules/todo-google/
!modules/weather/
# ...but still never track any module's local config override.
modules/*/config.local.json

# Secrets & local DB
.env
.env.local
*.sqlite
*.sqlite-journal
data/

# Personal/private Claude notes
CLAUDE.local.md

# Editor / OS
.DS_Store
.vscode/

MOUNTING_PLAN.md
