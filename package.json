{
  "name": "family-hub",
  "version": "0.1.0",
  "private": true,
  "description": "An open-source, modular smart-mirror / family dashboard for a wall-mounted display (Raspberry Pi friendly).",
  "license": "MIT",
  "author": "Andrew Hartwig",
  "homepage": "https://github.com/Andrew1431/family-hub#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Andrew1431/family-hub.git"
  },
  "bugs": {
    "url": "https://github.com/Andrew1431/family-hub/issues"
  },
  "keywords": [
    "smart-mirror",
    "magic-mirror",
    "dashboard",
    "family",
    "raspberry-pi",
    "fastify",
    "react",
    "self-hosted"
  ],
  "type": "module",
  "packageManager": "pnpm@10.15.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "seed": "node packages/tooling/seed.mjs",
    "dev": "concurrently -n core,ui -c blue,magenta \"pnpm --filter @hub/core dev\" \"pnpm --filter @hub/ui dev\"",
    "build": "pnpm -r build",
    "start": "pnpm --filter @hub/core start",
    "deploy": "ssh familyhub ~/.local/bin/familyhub-update.sh",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "concurrently": "^9.1.0",
    "typescript": "^5.6.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild"]
  }
}
